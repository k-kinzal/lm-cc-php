{
    "name": "k-kinzal/lm-cc-php",
    "description": "LM-CC: Language Model Code Complexity metric for PHP",
    "type": "library",
    "license": "MIT",
    "keywords": ["code-complexity", "llm", "static-analysis", "ci", "code-quality"],
    "authors": [
        {
            "name": "kinzal",
            "homepage": "https://github.com/k-kinzal"
        }
    ],
    "homepage": "https://github.com/k-kinzal/lm-cc-php",
    "support": {
        "issues": "https://github.com/k-kinzal/lm-cc-php/issues",
        "source": "https://github.com/k-kinzal/lm-cc-php"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "ext-tokenizer": "*",
        "symfony/console": "^6.0 || ^7.0",
        "symfony/http-client": "^6.0 || ^7.0",
        "symfony/yaml": "^6.0 || ^7.0",
        "symfony/finder": "^6.0 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lmcc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lmcc\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/lm-cc"
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
